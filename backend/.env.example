# Security
JWT_SECRET=change_me_to_a_long_random_string_at_least_32_chars

# Seeder
APP_SEED_ENABLED=true
APP_SEED_GAP_ENABLED=true
APP_SEED_GAP_TARGET_COUNT=1000
